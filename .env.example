# Copy this to .env and fill in real values. NEVER commit .env to git.
# Generate secrets with:  python -c "import secrets; print(secrets.token_urlsafe(48))"

# Flask
SECRET_KEY=replace-me-with-a-real-secret
FLASK_ENV=production

# Postgres (used by the app container).
# POSTGRES_PASSWORD has a clearly-unsafe default in docker-compose.yml so that
# overrides which delete the bundled `db` service don't fail compose's
# interpolation pass. ALWAYS set a real password here for any deployment
# (local or otherwise) that uses the bundled `db` service.
POSTGRES_USER=leaderboards
POSTGRES_PASSWORD=replace-me-with-a-real-password
POSTGRES_DB=leaderboards
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_RATELIMIT_URL=redis://redis:6379/1

# App tunables
SESSION_TTL_SECONDS=3600
CACHE_TTL_SECONDS=300
MAX_PLAYED_AT_SKEW_SECONDS=60

# Optional one-shot bootstrap password for `flask create-admin --password-env ADMIN_BOOTSTRAP_PASSWORD`.
# Unset this in the env after the first admin exists.
# ADMIN_BOOTSTRAP_PASSWORD=

# Trust exactly one reverse-proxy hop for X-Forwarded-For. Set to 0 to disable.
TRUSTED_PROXY_HOPS=1

# Cookie security. Set to 0 for local HTTP development; MUST be 1 in production behind TLS.
SESSION_COOKIE_SECURE=1
